{
  "info": {
    "name": "Clube de Leitura — Alexandria",
    "description": "Coleção completa de endpoints da API do Sistema de Clubes de Leitura.\n\nAutenticação: Após fazer login, o token JWT é automaticamente atribuído à variável de coleção `token`.\n\nBase URL: http://localhost:8080/api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Endpoints públicos de autenticação",
      "item": [
        {
          "name": "Cadastro",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.test('Cadastro realizado com sucesso', () => {",
                  "        pm.response.to.have.status(201);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Novo Usuário\",\n  \"email\": \"novo@email.com\",\n  \"senha\": \"Senha@123\",\n  \"fotoPerfil\": null,\n  \"tipoPerfil\": \"leitor\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/cadastro",
              "host": ["{{base_url}}"],
              "path": ["auth", "cadastro"]
            },
            "description": "Cadastra um novo usuário. Público."
          },
          "response": [
            {
              "name": "Sucesso",
              "status": "Created",
              "code": 201,
              "header": [],
              "body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"id\": 6,\n    \"nome\": \"Novo Usuário\",\n    \"email\": \"novo@email.com\",\n    \"fotoPerfil\": null,\n    \"tipoPerfil\": \"leitor\",\n    \"dataCadastro\": \"2026-06-13\"\n  }\n}"
            },
            {
              "name": "Email já cadastrado",
              "status": "Conflict",
              "code": 409,
              "header": [],
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"Email já cadastrado\",\n  \"code\": 409\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "    pm.test('Token armazenado na variável de coleção', () => {",
                  "        pm.expect(jsonData.data.token).to.not.be.empty;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@clubeleitura.com\",\n  \"senha\": \"Senha@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Realiza login e armazena o token JWT na variável de coleção `token`. Público."
          },
          "response": [
            {
              "name": "Sucesso",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiJ9...\",\n    \"tipo\": \"Bearer\",\n    \"email\": \"admin@clubeleitura.com\",\n    \"nome\": \"Admin\",\n    \"id\": 1\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Livros",
      "description": "CRUD de livros. GET /listar e GET /{id} são públicos; POST, PUT, DELETE exigem autenticação.",
      "item": [
        {
          "name": "Listar Livros",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/livros",
              "host": ["{{base_url}}"],
              "path": ["livros"],
              "query": [
                { "key": "titulo", "value": "", "disabled": true },
                { "key": "autor", "value": "", "disabled": true },
                { "key": "genero", "value": "", "disabled": true }
              ]
            },
            "description": "Lista todos os livros. Filtros opcionais por título, autor ou gênero. Público."
          }
        },
        {
          "name": "Buscar Livro por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/livros/1",
              "host": ["{{base_url}}"],
              "path": ["livros", "1"]
            },
            "description": "Busca um livro pelo ID. Público."
          }
        },
        {
          "name": "Criar Livro",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"O Senhor dos Anéis\",\n  \"autor\": \"J.R.R. Tolkien\",\n  \"genero\": \"Fantasia\",\n  \"descricao\": \"Uma épica jornada pela Terra Média.\",\n  \"tipo\": \"livro\",\n  \"dataPublicacao\": \"1954-07-29\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/livros",
              "host": ["{{base_url}}"],
              "path": ["livros"]
            },
            "description": "Cria um novo livro. Requer autenticação."
          }
        },
        {
          "name": "Atualizar Livro",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"O Senhor dos Anéis — Atualizado\",\n  \"autor\": \"J.R.R. Tolkien\",\n  \"genero\": \"Fantasia\",\n  \"descricao\": \"Edição revisada.\",\n  \"tipo\": \"livro\",\n  \"dataPublicacao\": \"1954-07-29\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/livros/1",
              "host": ["{{base_url}}"],
              "path": ["livros", "1"]
            },
            "description": "Atualiza os dados de um livro. Requer autenticação."
          }
        },
        {
          "name": "Deletar Livro",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/livros/1",
              "host": ["{{base_url}}"],
              "path": ["livros", "1"]
            },
            "description": "Remove um livro pelo ID. Requer autenticação."
          }
        }
      ]
    },
